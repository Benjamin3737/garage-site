{% extends 'base.html.twig' %}

{% block title %}Garage
{% endblock %}

{% block body %}

	<div class="position-relative overflow-hidden">

		<img src="/assets/img/hero.jpg" class="d-block w-100 object-fit-cover" style="height: 400px;" alt="Garage">

		<div class="position-absolute top-0 start-0 w-100 h-100 hero-shadow"></div>

		<div class="position-absolute top-50 start-50 translate-middle text-center text-white px-3 hero-content">
			<h1 class="mb-4">Bienvenue sur le site de notre garage !</h1>
			<p class="mb-3">
				Ouvert depuis 2021, nous proposons vente de véhicules d'occasion,
												            réparations, entretien et nettoyage à Grand Couronne.
			</p>
			<p>N'hésitez pas à nous contacter pour prendre rendez-vous.</p>
		</div>

	</div>

	<!-- CONTACT -->
	<section id="contact">
	<h2>Contact</h2>
	<form method="post">

		<div class="contact-row">
			<div>
				<label for="first_name">Prénom</label>
				<input type="text" id="first_name" placeholder="Prénom" name="first_name">
			</div>
			<div>
				<label for="last_name">Nom</label>
				<input type="text" id="last_name" placeholder="Nom" name="last_name">
			</div>
		</div>

		<div>
			<label for="email">Email</label>
			<input type="email" id="email" placeholder="Email" name="email">
		</div>

		<div>
			<label for="phone">Téléphone</label>
			<input type="tel" id="phone" placeholder="Téléphone" name="phone">
		</div>

		<div>
			<label for="subject">Sujet</label>
			<select id="subject" name="subject">
				<option value="">Sélectionnez un sujet</option>
				<option value="devis">Demande de devis</option>
				<option value="question">Question sur un service</option>
				<option value="retour">Retour d'expérience</option>
				<option value="autre">Autre demande</option>
			</select>
		</div>

		<div>
			<label for="content">Message</label>
			<textarea id="content" placeholder="Votre message" name="content"></textarea>
		</div>

		<button type="submit">Envoyer</button>
	</form>
	</section>

{% endblock %}
