<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">

		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>

		{% block stylesheets %}{% endblock %}

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
		<link rel="stylesheet" href="/app.css">

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>

	<body>
		<nav class="navbar flex-column ">

			<div class="text-center my-3">
				<img src="/assets/img/logo-05.png" alt="Logo" style="width: 100px;">
			</div>

			<div class="d-flex justify-content-center gap-4 pb-3">
				<a class="nav-link text-white" href="/">Véhicules</a>
				<a class="nav-link text-white" href="/services">Prestations atelier</a>
				<a class="nav-link text-white" href="/services">Prestations Nettoyage</a>
				<a class="nav-link text-white" href="/contact">Contact</a>
			</div>

		</nav>
		{% block body %}{% endblock %}
	</body>
</html>
